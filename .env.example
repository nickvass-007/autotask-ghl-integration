# ─────────────────────────────────────────────────────────────────────────────
# .env.example  ──  Committed template. Copy to .env and fill in real values.
#   cp .env.example .env       (the real .env is git-ignored and never committed)
#
# Every required variable NAME is present here with a blank/placeholder value so
# the structure is documented without leaking secrets (Spec §3.3).
# In production these come from Azure Key Vault via Managed Identity, NOT a file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime environment switch ───────────────────────────────────────────────
# The single most important switch. 'sandbox' | 'production'. DEFAULTS to sandbox.
# ⚠️ Operating against production must be a deliberate, obvious act (Spec §6).
ENVIRONMENT=sandbox

# Free-text label shown in logs / admin / Teams status, e.g. "Local dev (sandbox)".
DEPLOYMENT_LABEL=Local development

# ── Database ─────────────────────────────────────────────────────────────────
# Local development uses Postgres (docker-compose). Production uses Azure SQL.
# The schema is engine-portable (SQLAlchemy + Alembic, Spec §3.4) so only this
# URL changes between environments.
#   Postgres (local):  postgresql+psycopg://app:app@localhost:5432/autotask_ghl
#   Azure SQL (prod):  mssql+pyodbc://USER:PASS@SERVER.database.windows.net/DB?driver=ODBC+Driver+18+for+SQL+Server
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/autotask_ghl

# ── Autotask (SANDBOX credentials in local dev) ──────────────────────────────
# API-only user: username + secret + integration code. The zone-detection
# endpoint is called first to discover the correct API base URL (Spec §12.1).
# ⚠️ Sandbox and production each have their OWN api-only user & credentials.
#    One environment can never read the other's (Spec §6).
AUTOTASK_USERNAME=
AUTOTASK_SECRET=
AUTOTASK_INTEGRATION_CODE=
# Optional: override the zone-detection base. Leave blank to use the default
# zoneInformation endpoint. (e.g. https://webservicesN.autotask.net/atservicesrest)
AUTOTASK_ZONE_OVERRIDE_URL=
# Holding Account id for contacts awaiting a linkage decision (e.g. "Prospects –
# Unassigned"), so nothing floats orphaned (Spec §9.3). Blank = always raise an
# approval instead of attaching to a holding account.
AUTOTASK_HOLDING_ACCOUNT_ID=

# ── GoHighLevel (TEST sub-account / location in local dev) ───────────────────
# OAuth 2.0 Marketplace app with refresh-token rotation (Spec §12.1).
# GHL has no true sandbox — use a dedicated test sub-account/location (Spec §6).
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
# ⚠️ Path must not contain "ghl"/"highlevel" — GHL rejects branded redirect URIs.
GHL_REDIRECT_URI=http://localhost:8000/oauth/crm/callback
GHL_LOCATION_ID=
# OPTIONAL — local testing only. Real GHL marketplace webhooks are signed by
# GHL's private key (Ed25519, `x-ghl-signature`) and verified against their
# published public key baked into connectors/ghl.py — no secret to configure.
# Set this only to let scripts/send_test_contact.py send HMAC-signed fakes.
GHL_WEBHOOK_SECRET=
# Comma-separated OAuth scopes (least privilege). Stage 1 needs contacts.
GHL_SCOPES=contacts.readonly contacts.write

# ── Microsoft Teams Ops Bot (Azure Bot Service) ──────────────────────────────
# A real bot (not an incoming webhook) is required for interactive Approve/Reject
# button callbacks (Spec §11). Filled from the Bot/Entra app registration.
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_PASSWORD=
TEAMS_BOT_TENANT_ID=
# Shared secret the bot uses to authenticate its callbacks into the integration
# API (so a spoofed callback can't approve a change). (Spec §11.1 "verify the caller")
APPROVAL_CALLBACK_SECRET=

# ── Microsoft Graph (backup email channel for high-severity items, Spec §11) ──
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
ADMIN_ALERT_EMAILS=

# ── Circuit breaker thresholds (Spec §5.5) ───────────────────────────────────
# Pause ALL Autotask writes if either threshold is crossed in the rolling window.
CIRCUIT_BREAKER_MAX_CONFLICTS=25
CIRCUIT_BREAKER_MAX_FAILURE_RATE=0.30
CIRCUIT_BREAKER_WINDOW_MINUTES=15

# ── Approvals ────────────────────────────────────────────────────────────────
# Expired approvals default to PROTECT Autotask (no change) and re-notify (§11).
APPROVAL_EXPIRY_HOURS=48
# Auto-apply additive writes that fill an EMPTY Autotask field (default on, §5.2).
AUTO_APPLY_ADDITIVE=true

# ── Polling / reconciliation (Autotask has no comprehensive webhooks, §4) ─────
AUTOTASK_POLL_INTERVAL_SECONDS=300
RECONCILIATION_INTERVAL_SECONDS=3600
